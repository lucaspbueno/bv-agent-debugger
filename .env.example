# ============================================================
# GRAFANA — escolha uma das duas opções de autenticação
# ============================================================

# Opção A: Cookie de sessão (temporário, expira em horas)
# Como obter: Grafana → F12 → Network → query_range → Headers → valor após grafana_session=
# Renovar: Application tab → Cookies → jabutiagi.grafana.net → grafana_session
GRAFANA_SESSION=

# Opção B: Service Account Token (permanente, recomendado)
# Como obter: pedir ao admin do Grafana na Jabuti
GRAFANA_TOKEN=

# ============================================================
# APIs JABUTI / BV
# ============================================================

# API Key das APIs do BV (X-Api-Key)
BV_API_KEY=

# Worker ID para filtrar conversas (UAT)
BV_WORKER_ID=ca3afe48-39ec-4fb2-a365-29859aeab69f

# Credenciais de PROD (preencher quando disponível)
BV_API_KEY_PROD=
BV_WORKER_ID_PROD=

# ============================================================
# OLLAMA (inferência local — padrão: llama3.1)
# ============================================================
# Deixe em branco para usar o padrão. Exemplos: mistral, qwen2.5
OLLAMA_MODEL=

# ============================================================
# ANTHROPIC (provedor PRIMÁRIO de análise)
# ============================================================
# Crie em: https://console.anthropic.com/settings/keys
# Custo aproximado: $0,10 a $0,30 por análise
# Se vazio, o script usa direto o Ollama (fallback gratuito)
ANTHROPIC_API_KEY=

# Modelo do Claude (opcional). Default: claude-sonnet-4-6
ANTHROPIC_MODEL=

# ============================================================
# OLLAMA (FALLBACK gratuito — inferência local)
# ============================================================
# Modelo local do Ollama. Default: llama3.1
# Outras opções: qwen2.5, mistral, etc. (precisa rodar 'ollama pull <nome>')
OLLAMA_MODEL=

# ============================================================
# GRAFANA — escolha uma das duas opções de autenticação
# ============================================================

# Opção A: Cookie de sessão (temporário, expira em horas)
# Como obter: F12 → Application → Cookies → jabutiagi.grafana.net → grafana_session
GRAFANA_SESSION=

# Opção B: Service Account Token (permanente, recomendado)
# Como obter: peça ao admin do Grafana na Jabuti
GRAFANA_TOKEN=

# ============================================================
# APIs JABUTI / BV
# ============================================================

# UAT
BV_API_KEY=
BV_WORKER_ID=ca3afe48-39ec-4fb2-a365-29859aeab69f

# PROD (preencher quando disponível)
BV_API_KEY_PROD=
BV_WORKER_ID_PROD=
